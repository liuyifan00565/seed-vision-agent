/* miniprogram/pages/ai/index.wxss */

/* ========== 全局配置 ========== */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #E8F2FF 0%, #F5F9FF 50%, #FFFFFF 100%);
  position: relative;
  padding-bottom: calc(55px + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ========== 顶部导航 ========== */
.nav {
  padding: 24rpx 24rpx 20rpx 24rpx;
  background: linear-gradient(135deg, #5B7CFF 0%, #7B9FFF 100%);
  color: #fff;
  box-shadow: 0 4rpx 24rpx rgba(91, 124, 255, 0.25);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
  position: relative;
  z-index: 100;
}

.navLeft {
  display: flex;
  align-items: center;
}

.logoCircle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.4);
}

.logoIcon {
  font-size: 40rpx;
}

.navTitleWrap {
  display: flex;
  flex-direction: column;
}

.navTitle {
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.navSub {
  margin-top: 4rpx;
  font-size: 22rpx;
  opacity: 0.9;
}

.aiPoweredBadge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 14rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.badgeDot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #4ADE80;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.2); }
}

.aiPoweredText {
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
}

/* ========== 聊天容器 - 可滚动区域 ========== */
.chatContainer {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 30rpx;            /* 减少底部padding */
}

/* ========== 推荐词条区域 - 悬浮滑动卡片 ========== */
.quickStartSection {
  padding: 20rpx 0 24rpx 0;              /* 减少上下padding */
  background: transparent;
}

.sectionHeader {
  padding: 0 24rpx;
  margin-bottom: 16rpx;                  /* 减少间距 */
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.headerContent {
  display: flex;
  align-items: center;
  gap: 8rpx;                             /* 减少间距 */
}

.sparkleIcon {
  font-size: 26rpx;                      /* 缩小图标 */
  animation: sparkle 2s ease-in-out infinite;
}

@keyframes sparkle {
  0%, 100% { transform: rotate(0deg) scale(1); opacity: 1; }
  25% { transform: rotate(-15deg) scale(1.1); opacity: 0.8; }
  50% { transform: rotate(15deg) scale(1); opacity: 1; }
  75% { transform: rotate(-10deg) scale(1.05); opacity: 0.9; }
}

.headerTitle {
  font-size: 28rpx;                      /* 缩小标题 */
  font-weight: 700;
  background: linear-gradient(135deg, #5B7CFF 0%, #7B9FFF 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.headerHint {
  font-size: 20rpx;                      /* 缩小提示文字 */
  color: #999;
  display: flex;
  align-items: center;
  gap: 4rpx;
}

/* 横向滚动容器 */
.cardsScroller {
  width: 100%;
  white-space: nowrap;
}

.scrollContent {
  display: inline-flex;
  gap: 12rpx;                            /* 减少间距 */
  padding: 0 24rpx;
}

.scrollEndSpacer {
  width: 8rpx;
  flex-shrink: 0;
}

/* 悬浮卡片 - 缩小尺寸 */
.floatingCard {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 220rpx;                         /* 280 → 220 */
  height: 130rpx;                        /* 160 → 130 */
  background: #FFFFFF;
  border-radius: 20rpx;                  /* 24 → 20 */
  padding: 18rpx;                        /* 24 → 18 */
  box-shadow: 0 6rpx 20rpx rgba(91, 124, 255, 0.12);
  border: 2rpx solid rgba(91, 124, 255, 0.1);
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  animation: cardFloat 3s ease-in-out infinite;
}

/* 悬浮动画 */
@keyframes cardFloat {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-4rpx); }  /* 减小浮动幅度 */
}

.floatingCard:nth-child(2) {
  animation-delay: 0.2s;
}

.floatingCard:nth-child(3) {
  animation-delay: 0.4s;
}

.floatingCard:nth-child(4) {
  animation-delay: 0.6s;
}

.floatingCard:nth-child(5) {
  animation-delay: 0.8s;
}

.floatingCard:active {
  transform: scale(0.96) translateY(-2rpx);
  box-shadow: 0 4rpx 16rpx rgba(91, 124, 255, 0.2);
}

/* 精选卡片特效 */
.floatingCard.featured {
  background: linear-gradient(135deg, #5B7CFF 0%, #7B9FFF 100%);
  border: none;
  box-shadow: 0 10rpx 28rpx rgba(91, 124, 255, 0.3);
}

.floatingCard.featured::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transform: rotate(45deg);
  animation: shimmer 3s infinite;
}

@keyframes shimmer {
  0% { transform: translateX(-100%) rotate(45deg); }
  100% { transform: translateX(100%) rotate(45deg); }
}

.cardGradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 30% 40%, rgba(255, 255, 255, 0.2), transparent);
}

.cardIconBox {
  width: 64rpx;                          /* 80 → 64 */
  height: 64rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #E8F2FF 0%, #F5F9FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;                  /* 12 → 10 */
  box-shadow: 0 4rpx 16rpx rgba(91, 124, 255, 0.15);
  position: relative;
  z-index: 1;
}

.floatingCard.featured .cardIconBox {
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
}

.cardIconBox.secondary {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
}

.cardIconBox.tertiary {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.cardIconBox.quaternary {
  background: linear-gradient(135deg, #F3E5F5 0%, #E1BEE7 100%);
}

.cardBigIcon {
  font-size: 34rpx;                      /* 40 → 34 */
}

.cardTextArea {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  position: relative;
  z-index: 1;
}

.cardMainTitle {
  font-size: 24rpx;                      /* 28 → 24 */
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
  white-space: normal;
  word-break: break-all;
}

.floatingCard.featured .cardMainTitle {
  color: #FFFFFF;
}

.cardSubtext {
  font-size: 20rpx;                      /* 22 → 20 */
  color: #666;
  text-align: center;
  white-space: normal;
  word-break: break-all;
}

.floatingCard.featured .cardSubtext {
  color: rgba(255, 255, 255, 0.9);
}

.cardShine {
  position: absolute;
  top: 10rpx;                            /* 12 → 10 */
  right: 10rpx;
  width: 16rpx;                          /* 20 → 16 */
  height: 16rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.8) 0%, transparent 70%);
  animation: shine 2s ease-in-out infinite;
}

@keyframes shine {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 0.8; transform: scale(1.2); }
}

/* ========== 消息列表 ========== */
.messageList {
  padding: 20rpx 18rpx 100rpx 18rpx;  /* 减少底部padding */
}

.msgRow {
  display: flex;
  margin-bottom: 24rpx;
  animation: msgSlideIn 0.3s ease-out;
}

@keyframes msgSlideIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.msgRow.user {
  justify-content: flex-end;
}

.msgRow.assistant {
  justify-content: flex-start;
}

/* AI头像 */
.aiAvatarWrap {
  margin-right: 12rpx;
  flex-shrink: 0;
  position: relative;
  animation: avatarBounce 2s ease-in-out infinite;
}

@keyframes avatarBounce {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-4rpx); }
}

.aiAvatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5B7CFF 0%, #7B9FFF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(91, 124, 255, 0.3);
  border: 3rpx solid #FFFFFF;
  position: relative;
  z-index: 2;
}

/* 呼吸光晕 */
.avatarGlow {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(91, 124, 255, 0.4) 0%, transparent 70%);
  transform: translate(-50%, -50%);
  animation: glowPulse 2s ease-in-out infinite;
  z-index: 0;
}

@keyframes glowPulse {
  0%, 100% { 
    transform: translate(-50%, -50%) scale(1); 
    opacity: 0.6; 
  }
  50% { 
    transform: translate(-50%, -50%) scale(1.5); 
    opacity: 0.2; 
  }
}

/* 旋转环 */
.avatarRing {
  position: absolute;
  top: -6rpx;
  left: -6rpx;
  right: -6rpx;
  bottom: -6rpx;
  border-radius: 50%;
  border: 2rpx solid transparent;
  border-top-color: rgba(91, 124, 255, 0.6);
  border-right-color: rgba(91, 124, 255, 0.3);
  animation: ringRotate 3s linear infinite;
  z-index: 1;
}

@keyframes ringRotate {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.aiAvatarIcon {
  font-size: 28rpx;
  animation: iconBlink 3s ease-in-out infinite;
  position: relative;
  z-index: 3;
}

@keyframes iconBlink {
  0%, 90%, 100% { opacity: 1; }
  95% { opacity: 0.6; }
}

.msgContent {
  max-width: 75%;
  display: flex;
  flex-direction: column;
}

/* AI标识 */
.aiTag {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 12rpx;
  background: linear-gradient(135deg, #5B7CFF 0%, #7B9FFF 100%);
  border-radius: 12rpx 12rpx 4rpx 4rpx;
  margin-bottom: 8rpx;
  align-self: flex-start;
  box-shadow: 0 2rpx 8rpx rgba(91, 124, 255, 0.2);
}

.aiTagIcon {
  font-size: 18rpx;
}

.aiTagText {
  font-size: 20rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* 消息气泡 */
.bubble {
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
  line-height: 1.7;
  position: relative;
  word-break: break-word;
}

.userBubble {
  background: linear-gradient(135deg, #5B7CFF 0%, #7B9FFF 100%);
  color: #FFFFFF;
  border-top-right-radius: 6rpx;
  box-shadow: 0 4rpx 16rpx rgba(91, 124, 255, 0.25);
}

.aiBubble {
  background: #FFFFFF;
  color: #1a1a1a;
  border-top-left-radius: 6rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid rgba(91, 124, 255, 0.08);
}

.bubbleText {
  font-size: 28rpx;
  white-space: pre-wrap;
  word-break: break-word;
  line-height: 1.7;
}

/* 图片消息 */
.msgImage {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.msgImageContent {
  width: 100%;
  max-width: 400rpx;
  height: 280rpx;
  border-radius: 16rpx;
  background: #F5F9FF;
}

.imageMask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(91, 124, 255, 0.5), rgba(123, 159, 255, 0.5));
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.msgImage:active .imageMask {
  opacity: 1;
}

.imageMaskIcon {
  font-size: 48rpx;
  color: #FFFFFF;
}

.imageCaption {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 打字动画 */
.typingIndicator {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
}

.typingDot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5B7CFF 0%, #7B9FFF 100%);
  animation: typingBounce 1.4s infinite;
}

.typingDot:nth-child(2) {
  animation-delay: 0.2s;
}

.typingDot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typingBounce {
  0%, 60%, 100% {
    transform: translateY(0);
    opacity: 0.5;
  }
  30% {
    transform: translateY(-10rpx);
    opacity: 1;
  }
}

.typingText {
  font-size: 22rpx;
  color: #5B7CFF;
  font-weight: 500;
  margin-left: 4rpx;
}

/* 时间戳 */
.msgTime {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
  margin-left: 8rpx;
}

.msgTimeLabel {
  color: #5B7CFF;
  font-weight: 600;
}

/* 操作按钮 */
.msgActions {
  display: flex;
  gap: 8rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.actionBtn {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 14rpx;
  background: rgba(91, 124, 255, 0.06);
  border: 1rpx solid rgba(91, 124, 255, 0.15);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.actionBtn:active {
  transform: scale(0.95);
  background: rgba(91, 124, 255, 0.12);
}

.actionBtnText {
  font-size: 22rpx;
  color: #5B7CFF;
  font-weight: 500;
}

.bottomSpacer {
  height: calc(150rpx + env(safe-area-inset-bottom)); /* 大幅减少底部留白 */
}

/* ========== 固定底部输入栏 ========== */
.fixedInputBar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 135rpx;                    /* 默认值，会被动态style覆盖 */
  background: #FFFFFF;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  z-index: 999;                      /* 提高层级 */
  border-radius: 24rpx 24rpx 0 0;
  transition: bottom 0.25s ease-out; /* 平滑过渡动画 */
}

/* 图片预览 */
.imagePreview {
  padding: 12rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.previewImageBox {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.previewImage {
  width: 100%;
  height: 100%;
}

.previewOverlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.6) 100%);
  padding: 4rpx 8rpx;
}

.previewLabel {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.removePreviewBtn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.removePreviewBtn:active {
  background: #EEEEEE;
  transform: scale(0.9);
}

.removeIcon {
  font-size: 32rpx;
  color: #666;
  font-weight: 300;
}

/* 输入区域 */
.inputWrapper {
  padding: 10rpx 16rpx;
  display: flex;
  align-items: center;                   /* 改为居中对齐 */
  gap: 10rpx;
}

.cameraBtn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8F2FF 0%, #D4E7FF 100%);
  border: 2rpx solid rgba(91, 124, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 12rpx rgba(91, 124, 255, 0.15);
  position: relative;
  overflow: hidden;
}

.cameraBtn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.6), transparent);
  transition: left 0.5s ease;
}

.cameraBtn:active {
  background: linear-gradient(135deg, #D4E7FF 0%, #C0DBFF 100%);
  transform: scale(0.92);
  box-shadow: 0 1rpx 6rpx rgba(91, 124, 255, 0.2);
}

.cameraBtn:active::before {
  left: 100%;
}

.cameraBtnContent {
  position: relative;
  z-index: 1;
  animation: iconPulse 2s ease-in-out infinite;
}

@keyframes iconPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.cameraBtnIcon {
  font-size: 28rpx;
}

/* 多行输入框容器 */
.multiInputBox {
  flex: 1;
  background: #F5F5F5;
  border-radius: 28rpx;
  padding: 12rpx 18rpx;
  min-height: 60rpx;
  max-height: 200rpx;                 /* 最大高度 */
  display: flex;
  align-items: center;
}

.multiInputField {
  width: 100%;
  color: #1a1a1a;
  font-size: 26rpx;
  line-height: 1.6;
  min-height: 36rpx;
  max-height: 176rpx;                 /* 对应容器最大高度 */
}

.inputPlaceholder {
  color: #999;
}

.sendBtn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5B7CFF 0%, #7B9FFF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(91, 124, 255, 0.35);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  flex-shrink: 0;
}

.sendBtn:active {
  transform: scale(0.9);
  box-shadow: 0 2rpx 10rpx rgba(91, 124, 255, 0.4);
}

.sendBtn.disabled {
  opacity: 0.4;
  box-shadow: 0 2rpx 8rpx rgba(91, 124, 255, 0.2);
}

.sendBtnIcon {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 700;
}
