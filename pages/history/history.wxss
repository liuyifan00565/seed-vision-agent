/* pages/history/history.wxss */
.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 20rpx;
  border-top: 1rpx solid rgba(0,0,0,0.05);
}

.left {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.expr {
  font-size: 28rpx;
  color: #2b2f38;
  word-break: break-all;
}

.meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #9aa4b2;
}

.right {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  white-space: nowrap;
}

.eq {
  font-size: 26rpx;
  color: #9aa4b2;
}

.res {
  font-size: 28rpx;
  font-weight: 700;
  color: #3b5cff;
}
