/* custom-tab-bar/index.wxss */
@font-face{
  font-family:"iconfont";
  src:url("data:font/ttf;base64,");
}

.iconfont{
  font-family:"iconfont" !important;
  font-style: normal;
  font-weight: normal;
  font-size: 60rpx;
  line-height: 1;
}

/* custom-tab-bar/index.wxss */

.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  width: 100%;
  /* 使用calc动态计算高度,适配不同屏幕 */
  height: 39px ;
  background: white;
  display: flex;
  flex-direction: row;
  /* 关键:使用padding-bottom适配安全区 */
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -1px 8px rgba(0, 0, 0, 0.08);
  z-index: 9999;
  box-sizing: content-box;  /* 改为content-box,让padding不影响高度 */
}

.tab-bar-item {
  flex: 1;
  text-align: center;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  /* 使用百分比让间距自适应 */
  padding:0px 0 13px 0;
  box-sizing: border-box;
  position: relative;
  transition: all 0.2s ease;
  height: 50px;  /* 固定内容区高度 */
}

/* 点击缩放动画 */
.tab-bar-item:active {
  transform: scale(0.9);
}

.tab-bar-icon {
  font-family: "iconfont";
  font-size: 33px;  /* 使用固定大小,在所有设备上一致 */
  margin-bottom: -4px;
  transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  transform: scale(1);
  line-height: 1;
}

.tab-bar-text {
  font-size: 10px;
  font-weight: 400;
  transition: all 0.3s ease;
  line-height: 1.2;
  white-space: nowrap;  /* 防止文字换行 */
}

/* 未选中状态 */
.tab-bar-icon,
.tab-bar-text {
  color: #999;
}

/* 选中状态 */
.selected .tab-bar-icon {
  color: #5A7FFD;
  transform: scale(1.15);
}

.selected .tab-bar-text {
  color: #5A7FFD;
  font-weight: 600;
}

/* 点击波纹效果 */
.tab-bar-item::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(90, 127, 253, 0.15);
  transform: translate(-50%, -50%);
  transition: width 0.4s ease-out, height 0.4s ease-out, opacity 0.4s ease-out;
  opacity: 0;
  z-index: -1;
}

.tab-bar-item:active::after {
  width: 50px;
  height: 50px;
  opacity: 1;
}